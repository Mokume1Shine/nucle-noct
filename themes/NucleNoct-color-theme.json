    }
  ],
  "semanticTokenColors": {
    // Semantic Highlighting 用の役割色。
    "namespace": "#8FBCC6",
    "class": "#F3FBFD",
    "interface": "#B8E4EB",
    "enum": "#FE9F2F",
    "typeParameter": "#8FBCC6",
    "constructor": "#F3FBFD",
    "function": "#00B8D6",
    "method": "#7BC7D4",
    "property": "#A2D5DF",
    "variable": "#C8E0E4",
    "parameter": "#8FBCC6",
    "struct": "#F3FBFD",
    "enumMember": "#F3C97A",
    "variable.readonly": "#F3C97A",
    "variable.defaultLibrary": "#B8E4EB",
    "function.defaultLibrary": "#7BC7D4",
    // Semantic modifier と装飾の例外。
    "class.declaration": {
      "foreground": "#F3FBFD",
      "fontStyle": "bold"
    },
    "method.deprecated": {
      "foreground": "#FEB656",
      "fontStyle": "strikethrough"
    },
    "function.deprecated": {
      "foreground": "#FEB656",
      "fontStyle": "strikethrough"
    }
  }
}
