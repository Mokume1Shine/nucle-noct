  "tokenColors": [
    // コメントなどの弱い構文要素。
    // コメントは消えない程度に後退させるため、柔らかい灰青系で扱う。
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6B8791",
        "fontStyle": "italic"
      }
    },
    // 制御構文と言語構造。
    // キーワードはソース内で数少ない一貫した暖色の支点として扱う。
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#F7A32E"
      }
    },
    // 演算子と句読点系。
    // 制御キーワードと混ざらないよう、より明るい寒色で構文の接着剤として見せる。
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator.key-value",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#63D4EA"
      }
    },
    // 型システムと宣言系。
    // 型に関わる要素は本文とアクセント色の中間に置き、主張しすぎないようにする。
    {
      "scope": [
        "storage.type",
        "support.type",
        "support.class",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#A9D3DE"
      }
    },
    // 呼び出し可能なシンボル。
    // 関数は強いシアン、メソッドは少し柔らかい色にして階層差を保つ。
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#18B7D8"
      }
    },
    {
      "scope": [
        "entity.name.method",
        "meta.method-call",
        "support.function.method"
      ],
      "settings": {
        "foreground": "#63D4EA"
      }
    },
    // マークアップと値リテラル。
    // タグやエスケープは暖色、属性・文字列・正規表現は寒色で整理する。
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#F7A32E"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#8CC5D2"
      }
    },
    // JSON のキー名。
    // 文字列値と同化しないよう、キーは一段強い青系で分離する。
    {
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name.jsonc",
        "meta.object-literal.key.json string.quoted.double.json",
        "meta.object-literal.key.jsonc string.quoted.double.jsonc",
        "meta.object.member variable.other.readwrite.json",
        "meta.object.member variable.other.readwrite.jsonc",
        "meta.object.member variable.other.property.json",
        "meta.object.member variable.other.property.jsonc",
        "meta.mapping.key.json string.quoted",
        "meta.mapping.key.jsonc string.quoted"
      ],
      "settings": {
        "foreground": "#63D4EA"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#B8E3EC"
      }
    },
    {
      "scope": [
        "string.template meta.embedded",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#F6C16D"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#8CC5D2"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#F7A32E"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character"
      ],
      "settings": {
        "foreground": "#F6C16D"
      }
    },
    // 変数と値の種類。
    // 通常の値は中立、引数は寒色寄り、定数は暖色寄りで役割差を出す。
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#C7E2E8"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#8CC5D2"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#A9D3DE"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "entity.name.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#F6C16D"
      }
    },
    {
      "scope": [
        "entity.name.enum",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#FFC05F"
      }
    },
    // Markdown の強調と文章要素。
    // ドキュメント系は配色よりタイポグラフィ差で見せる方針を取る。
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#D9EEF2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C7E2E8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#B8E3EC",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#F7A32E"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#8CC5D2"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "markup.link"
      ],
      "settings": {
        "foreground": "#63D4EA",
        "fontStyle": "underline"
      }
    },
    // 不正値と状態系の疑似トークン。
    // warning / error も既定の赤紫へ寄せず、アンバー系でテーマ全体の声を保つ。
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F6C16D",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "invalid.deprecated",
        "invalid.deprecated.trailing-whitespace"
      ],
      "settings": {
        "foreground": "#F6C16D",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "token.info-token",
      "settings": {
        "foreground": "#18B7D8"
      }
    },
    {
      "scope": "token.warn-token",
      "settings": {
        "foreground": "#F6C16D"
      }
    },
    {
      "scope": "token.error-token",
      "settings": {
        "foreground": "#F7A32E"
      }
    },
    {
      "scope": "token.debug-token",
      "settings": {
        "foreground": "#A9D3DE"
      }
    }
  ],
  "semanticTokenColors": {
    // Semantic Highlighting 用のシンボル役割色。
    // TextMate 側の役割分担と揃え、semantic token だけ浮かないようにする。
    "namespace": "#8CC5D2",
    "class": "#A9D3DE",
    "interface": "#B8E3EC",
    "enum": "#FFC05F",
    "typeParameter": "#8CC5D2",
    "function": "#18B7D8",
    "method": "#63D4EA",
    "property": "#A9D3DE",
    "variable": "#C7E2E8",
    "parameter": "#8CC5D2",
    "enumMember": "#F6C16D",
    "variable.readonly": "#F6C16D",
    "variable.defaultLibrary": "#A9D3DE",
    "function.defaultLibrary": "#63D4EA",
    // Semantic modifier と文字装飾の例外。
    // 太字の宣言と打ち消し線の deprecated 系だけを装飾ベースの例外として扱う。
    "class.declaration": {
      "foreground": "#D9EEF2",
      "fontStyle": "bold"
    },
    "method.deprecated": {
      "foreground": "#F6C16D",
      "fontStyle": "strikethrough"
    },
    "function.deprecated": {
      "foreground": "#F6C16D",
      "fontStyle": "strikethrough"
    }
  }
}
