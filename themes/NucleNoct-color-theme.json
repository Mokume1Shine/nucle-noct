  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6B8791",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#F7A32E"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator.key-value",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#63D4EA"
      }
    },
    {
      "scope": [
        "storage.type",
        "support.type",
        "support.class",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#A9D3DE"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#18B7D8"
      }
    },
    {
      "scope": [
        "entity.name.method",
        "meta.method-call",
        "support.function.method"
      ],
      "settings": {
        "foreground": "#63D4EA"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#F7A32E"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#8CC5D2"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#B8E3EC"
      }
    },
    {
      "scope": [
        "string.template meta.embedded",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#F6C16D"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#8CC5D2"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#F7A32E"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character"
      ],
      "settings": {
        "foreground": "#F6C16D"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#C7E2E8"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#8CC5D2"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#A9D3DE"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "entity.name.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#F6C16D"
      }
    },
    {
      "scope": [
        "entity.name.enum",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#FFC05F"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#D9EEF2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C7E2E8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#B8E3EC",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#F7A32E"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#8CC5D2"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "markup.link"
      ],
      "settings": {
        "foreground": "#63D4EA",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F6C16D",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "invalid.deprecated",
        "invalid.deprecated.trailing-whitespace"
      ],
      "settings": {
        "foreground": "#F6C16D",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#8CC5D2",
    "class": "#A9D3DE",
    "interface": "#B8E3EC",
    "enum": "#FFC05F",
    "typeParameter": "#8CC5D2",
    "function": "#18B7D8",
    "method": "#63D4EA",
    "property": "#A9D3DE",
    "variable": "#C7E2E8",
    "parameter": "#8CC5D2",
    "enumMember": "#F6C16D",
    "variable.readonly": "#F6C16D",
    "variable.defaultLibrary": "#A9D3DE",
    "function.defaultLibrary": "#63D4EA",
    "class.declaration": {
      "foreground": "#D9EEF2",
      "fontStyle": "bold"
    },
    "method.deprecated": {
      "foreground": "#F6C16D",
      "fontStyle": "strikethrough"
    },
    "function.deprecated": {
      "foreground": "#F6C16D",
      "fontStyle": "strikethrough"
    }
  }
