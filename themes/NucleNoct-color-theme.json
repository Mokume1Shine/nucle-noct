{
  "name": "NucleNoct",
  "colors": {
    "editor.background": "#032B3A",
    "editor.foreground": "#C7E2E8",
    "editorCursor.foreground": "#F7A32E",
    "editor.lineHighlightBackground": "#0A3444",
    "editor.selectionBackground": "#1A5C70AA",
    "editor.inactiveSelectionBackground": "#144D6080",
    "editorLineNumber.foreground": "#5E7A85",
    "editorLineNumber.activeForeground": "#A9D3DE",
    "editorIndentGuide.background1": "#294854",
    "editorIndentGuide.activeBackground1": "#4E7685",
    "editorWhitespace.foreground": "#294854",
    "editorBracketMatch.background": "#18B7D822",
    "editorBracketMatch.border": "#18B7D8",
    "focusBorder": "#18B7D8",
    "sideBar.background": "#0A3141",
    "activityBar.background": "#082331",
    "panel.background": "#082B39",
    "statusBar.background": "#082331",
    "statusBar.foreground": "#C7E2E8",
    "tab.activeBackground": "#0B3B4C",
    "tab.inactiveBackground": "#082B39",
    "tab.activeForeground": "#D9EEF2",
    "tab.inactiveForeground": "#71909A",
    "tab.activeBorderTop": "#F7A32E",
    "list.hoverBackground": "#11465A",
    "list.activeSelectionBackground": "#14546A",
    "button.background": "#F7A32E",
    "button.foreground": "#032B3A",
    "button.hoverBackground": "#FFC05F",
    "badge.background": "#18B7D8",
    "badge.foreground": "#032B3A",
    "terminal.ansiBlack": "#082331",
    "terminal.ansiBlue": "#18B7D8",
    "terminal.ansiCyan": "#8CC5D2",
    "terminal.ansiYellow": "#F7A32E",
    "terminal.ansiWhite": "#C7E2E8",
    "terminal.ansiBrightBlack": "#5E7A85",
    "terminal.ansiBrightBlue": "#63D4EA",
    "terminal.ansiBrightCyan": "#B8E3EC",
    "terminal.ansiBrightYellow": "#F6C16D"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6B8791",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage", "storage.type"],
      "settings": {
        "foreground": "#F7A32E"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#18B7D8"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type"],
      "settings": {
        "foreground": "#A9D3DE"
      }
    },
    {
      "scope": ["string"],
      "settings": {
        "foreground": "#B8E3EC"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#F6C16D"
      }
    },
    {
      "scope": ["variable", "meta.definition.variable"],
      "settings": {
        "foreground": "#C7E2E8"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#8CC5D2"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#FFD8D2",
        "background": "#A94B3F"
      }
    }
  ]
}
