  "tokenColors": [
    // コメントなどの弱い構文要素。
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6D8A91",
        "fontStyle": "italic"
      }
    },
    // 制御構文と言語構造。
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#A2D5DF"
      }
    },
    // 演算子と句読点。
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator.key-value",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#66B5C3"
      }
    },
    // 型システムと宣言。
    {
      "scope": [
        "storage.type",
        "support.type",
        "support.class",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#D7EDF2"
      }
    },
    // 呼び出し可能なシンボル。
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#00B8D6"
      }
    },
    {
      "scope": [
        "entity.name.method",
        "meta.method-call",
        "support.function.method"
      ],
      "settings": {
        "foreground": "#7BC7D4"
      }
    },
    // Java の型名とメンバーアクセス。
    {
      "scope": [
        "support.class.java",
        "entity.name.type.class.java",
        "storage.type.class.java",
